{
  "version": 1,
  "defaultComponents": [
    "core",
    "docs-runtime",
    "rules-common",
    "templates",
    "contexts"
  ],
  "components": {
    "core": {
      "description": "核心工作流：Skills、Agents、基础 Hooks",
      "required": true,
      "sources": [
        "skills/",
        "agents/",
        "hooks/",
        ".claude-plugin/",
        ".codex/",
        "manifests/",
        "install.sh",
        "scripts/validate.js",
        "scripts/install-manifest.js",
        "scripts/doctor.js",
        "scripts/init-project.js",
        "scripts/repair.js",
        "scripts/scaffold-feature.js",
        "scripts/update-spec-state.js",
        "scripts/update-verification.js",
        "scripts/check-version.js",
        "scripts/lib/",
        "package.json",
        "README.md"
      ]
    },
    "docs-runtime": {
      "description": "运行时与初始化所需指南",
      "required": false,
      "sources": [
        "docs/guides/development-spec.md",
        "docs/guides/workflow-guide.md",
        "docs/guides/change-set-model.md",
        "docs/guides/runtime-matrix.md",
        "docs/guides/generated-vs-curated-policy.md"
      ]
    },
    "rules-common": {
      "description": "通用编码规范（所有项目推荐安装）",
      "required": false,
      "sources": [
        "configs/rules/common/"
      ]
    },
    "rules-java": {
      "description": "Java / Spring Boot 编码规范",
      "requires": "rules-common",
      "sources": [
        "configs/rules/java/"
      ]
    },
    "rules-mysql": {
      "description": "MySQL 数据库规范",
      "requires": "rules-common",
      "sources": [
        "configs/rules/mysql/"
      ]
    },
    "templates": {
      "description": "文档模板：CLAUDE.md、PRD、技术方案等",
      "required": false,
      "sources": [
        "configs/templates/"
      ]
    },
    "contexts": {
      "description": "工作模式定义：dev / research / review",
      "required": false,
      "sources": [
        "contexts/"
      ]
    },
    "tests": {
      "description": "仓库脚本与 Hook 的最小回归测试",
      "required": false,
      "sources": [
        "tests/"
      ]
    },
    "repo-maintenance": {
      "description": "框架仓库维护材料：优化方案、执行计划等",
      "required": false,
      "sources": [
        "docs/plans/",
        "docs/workflow-optimization-plan.md",
        "docs/workflow-optimization-wp-a-checklist.md",
        "docs/workflow-optimization-wp-b-checklist.md",
        "docs/workflow-optimization-wp-c-checklist.md",
        "docs/workflow-optimization-wp-d-checklist.md",
        "docs/workflow-optimization-wp-e-checklist.md"
      ]
    }
  },
  "profiles": {
    "java-fullstack": {
      "description": "Java + Spring Boot + MySQL 全栈",
      "components": ["core", "docs-runtime", "rules-common", "rules-java", "rules-mysql", "templates", "contexts"]
    },
    "java-light": {
      "description": "Java 后端（无数据库规范）",
      "components": ["core", "docs-runtime", "rules-common", "rules-java", "templates"]
    },
    "minimal": {
      "description": "仅核心工作流，不带规范",
      "components": ["core", "docs-runtime"]
    }
  },
  "stackDetection": {
    "java": {
      "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
      "components": ["rules-java"]
    },
    "mysql": {
      "files": ["*.sql", "src/main/resources/db/", "src/main/resources/schema.sql"],
      "dirs": ["flyway", "liquibase", "src/main/resources/db"],
      "components": ["rules-mysql"]
    },
    "spring-boot": {
      "files": ["pom.xml"],
      "contentPatterns": ["spring-boot", "org.springframework"],
      "components": ["rules-java"]
    }
  }
}
