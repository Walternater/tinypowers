{
  "name": "tinypowers",
  "private": true,
  "version": "0.0.0",
  "description": "Validation, diagnostics, and maintenance entrypoints for the tinypowers workflow repository.",
  "scripts": {
    "validate": "node scripts/validate.js",
    "doctor": "node scripts/doctor.js",
    "repair": "node scripts/repair.js",
    "scaffold:feature": "node scripts/scaffold-feature.js",
